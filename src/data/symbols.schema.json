{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/symbols.schema.json",
  "title": "Unicode Symbol Entry",
  "type": "object",
  "required": [
    "id",
    "char",
    "name",
    "codepoints",
    "primaryCategory",
    "tags",
    "searchKeywords"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "char": {
      "type": "string",
      "minLength": 1
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "aliases": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "codepoints": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^U\\+[0-9A-F]{2,6}$"
      }
    },
    "primaryCategory": {
      "$ref": "#/$defs/category"
    },
    "category": {
      "$ref": "#/$defs/category",
      "description": "Backward-compatible alias for primaryCategory."
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "searchKeywords": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "curatedSets": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
      },
      "uniqueItems": true
    },
    "contextualNote": {
      "type": "string"
    },
    "note": {
      "type": "string",
      "description": "Legacy field preserved for compatibility; prefer contextualNote."
    },
    "featured": {
      "type": "boolean",
      "default": false
    },
    "flags": {
      "type": "object",
      "properties": {
        "sensitive": {
          "type": "boolean",
          "default": false
        }
      },
      "additionalProperties": false
    },
    "knowledge": {
      "$ref": "#/$defs/knowledge"
    },
    "supportsSkinTone": {
      "type": "boolean",
      "description": "Whether this emoji supports Unicode skin tone modifiers."
    },
    "generatedVariants": {
      "type": "array",
      "description": "Optional pre-generated Unicode variants (typically skin tone variants).",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "preferredDefaultSkinTone": {
      "type": "string",
      "enum": [
        "🏻",
        "🏼",
        "🏽",
        "🏾",
        "🏿"
      ],
      "description": "Optional preferred default skin tone modifier for future personalization."
    }
  },
  "$defs": {
    "category": {
      "type": "string",
      "enum": [
        "punctuation",
        "quotation-marks",
        "arrows",
        "math-symbols",
        "currency",
        "check-marks",
        "crosses",
        "stars",
        "geometric-shapes",
        "box-drawing",
        "technical-computing",
        "whitespace-invisible",
        "emoji-smileys",
        "emoji-people",
        "emoji-nature",
        "emoji-food",
        "emoji-travel",
        "emoji-objects",
        "flags",
        "political-ideological",
        "religious-spiritual"
      ]
    },
    "sourceType": {
      "type": "string",
      "enum": [
        "editorial",
        "unicode",
        "cldr",
        "wikidata",
        "dbpedia",
        "open-data",
        "other"
      ]
    },
    "externalLink": {
      "type": "object",
      "required": [
        "label",
        "url"
      ],
      "properties": {
        "label": {
          "type": "string",
          "minLength": 1
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "sourceType": {
          "$ref": "#/$defs/sourceType"
        }
      },
      "additionalProperties": false
    },
    "knowledge": {
      "type": "object",
      "properties": {
        "description": {
          "type": "string"
        },
        "history": {
          "type": "string"
        },
        "culturalContext": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        },
        "externalLinks": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/externalLink"
          }
        },
        "sourceLabels": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
